# TradePilot E2E Test Credentials
# Copy this file to .env.test and fill in with your test user credentials
#
# To use:
# 1. Copy this file: cp .env.test.example .env.test
# 2. Fill in your Firebase test user credentials
# 3. Run tests: npx playwright test --project=authenticated

# Regular user (must have status: 'active', role: 'user' in Firestore)
TEST_USER_EMAIL=your-test-user@example.com
TEST_USER_PASSWORD=your-test-password

# Admin user (must have status: 'active', role: 'admin' in Firestore)
TEST_ADMIN_EMAIL=your-admin@example.com
TEST_ADMIN_PASSWORD=your-admin-password
