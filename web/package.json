{
  "name": "tradepilot-web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:journeys": "playwright test --project=journeys",
    "test:journeys:headed": "playwright test --project=journeys-headed",
    "test:journeys:ui": "playwright test --project=journeys --ui",
    "test:journeys:debug": "playwright test --project=journeys --debug",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect --url=http://localhost:4321",
    "analyze": "ANALYZE=true astro build"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@nanostores/react": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.18.0",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.575.0",
    "nanostores": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "playwright-lighthouse": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "vitest": "^2.1.0"
  }
}
