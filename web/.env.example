# TradePilot Web Environment Variables
# Copy this file to .env.development or .env.production and fill in your values

# =============================================================================
# Firebase Configuration
# =============================================================================
# Get these from Firebase Console > Project Settings > Your Apps > Web App

PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000

# =============================================================================
# Firebase Emulators (Development Only)
# =============================================================================
# Set to 'true' to use Firebase emulators instead of production Firebase

PUBLIC_USE_FIREBASE_EMULATORS=false

# Emulator hosts and ports (defaults shown)
PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost
PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
PUBLIC_FIREBASE_FIRESTORE_EMULATOR_HOST=localhost
PUBLIC_FIREBASE_FIRESTORE_EMULATOR_PORT=8080
PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=localhost
PUBLIC_FIREBASE_STORAGE_EMULATOR_PORT=9199

# =============================================================================
# App Configuration
# =============================================================================

PUBLIC_APP_URL=http://localhost:4321
PUBLIC_APP_NAME=TradePilot
