---
import MainLayout from '../../../layouts/MainLayout.astro';
import { RegisterForm } from '../../../components/auth/RegisterForm';

const { code } = Astro.params;
---

<MainLayout title="Join TradePilot">
  <div class="auth-page">
    <div class="auth-container">
      <div class="auth-header">
        <a href="/" class="logo">
          <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="var(--accent)"/>
            <path d="M8 20L12 12L18 16L24 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="8" r="2" fill="white"/>
          </svg>
        </a>
        <h1>You're invited!</h1>
        <p>Create your TradePilot account</p>
      </div>

      <div id="invite-status" class="invite-checking">
        <div class="loading-spinner">
          <svg width="24" height="24" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" stroke="var(--accent)" stroke-width="3" fill="none" stroke-dasharray="31.4" stroke-linecap="round">
              <animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/>
            </circle>
          </svg>
        </div>
        <p>Validating invite code...</p>
      </div>

      <div id="invite-valid" class="invite-content" style="display: none;">
        <RegisterForm client:load inviteCode={code} />

        <div class="auth-footer">
          <p>Already have an account? <a href="/auth/login">Log in</a></p>
        </div>
      </div>

      <div id="invite-invalid" class="invite-error" style="display: none;">
        <div class="error-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--negative)" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <h2>Invalid Invite</h2>
        <p id="error-message">This invite code is not valid.</p>
        <div class="error-actions">
          <a href="/" class="btn btn-secondary">Go to Homepage</a>
          <a href="/auth/login" class="btn btn-primary">Log In</a>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script define:vars={{ code }}>
  import { validateInvite } from '../../../lib/invites';

  async function checkInvite() {
    const statusEl = document.getElementById('invite-status');
    const validEl = document.getElementById('invite-valid');
    const invalidEl = document.getElementById('invite-invalid');
    const errorMsgEl = document.getElementById('error-message');

    try {
      const result = await validateInvite(code);

      if (result.valid) {
        statusEl.style.display = 'none';
        validEl.style.display = 'block';
      } else {
        statusEl.style.display = 'none';
        invalidEl.style.display = 'block';
        if (errorMsgEl && result.error) {
          errorMsgEl.textContent = result.error;
        }
      }
    } catch (error) {
      statusEl.style.display = 'none';
      invalidEl.style.display = 'block';
      if (errorMsgEl) {
        errorMsgEl.textContent = 'Unable to validate invite code. Please try again.';
      }
    }
  }

  // Check invite on load
  checkInvite();
</script>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .auth-container {
    width: 100%;
    max-width: 400px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .logo {
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .auth-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .auth-header p {
    color: var(--text-muted);
  }

  .invite-checking {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 3rem;
    text-align: center;
  }

  .invite-checking .loading-spinner {
    margin-bottom: 1rem;
  }

  .invite-checking p {
    color: var(--text-muted);
  }

  .invite-error {
    background-color: var(--bg-secondary);
    border: 1px solid var(--negative);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    text-align: center;
  }

  .error-icon {
    margin-bottom: 1.5rem;
  }

  .invite-error h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--negative);
  }

  .invite-error p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .auth-footer {
    text-align: center;
    margin-top: 1.5rem;
  }

  .auth-footer p {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .auth-footer a {
    color: var(--accent);
    font-weight: 500;
  }
</style>
