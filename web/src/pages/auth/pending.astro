---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Pending Approval">
  <div class="auth-page">
    <div class="auth-container">
      <div class="pending-card">
        <div class="pending-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--warning)" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>

        <h1>Account Pending Approval</h1>

        <p class="description">
          Your account has been created successfully. An administrator will review
          and approve your account shortly.
        </p>

        <div class="info-box">
          <h3>What happens next?</h3>
          <ul>
            <li>An admin will review your registration</li>
            <li>You'll receive an email when approved</li>
            <li>Once approved, you can access the dashboard</li>
          </ul>
        </div>

        <div class="actions">
          <a href="/" class="btn btn-secondary">Return to Home</a>
          <button id="logout-btn" class="btn btn-ghost">Sign Out</button>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { signOut } from '../../lib/firebase';

  const logoutBtn = document.getElementById('logout-btn');
  logoutBtn?.addEventListener('click', async () => {
    await signOut();
    window.location.href = '/';
  });
</script>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .auth-container {
    width: 100%;
    max-width: 480px;
  }

  .pending-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    text-align: center;
  }

  .pending-icon {
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .description {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .info-box {
    background-color: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: left;
    margin-bottom: 2rem;
  }

  .info-box h3 {
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--text-secondary);
  }

  .info-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .info-box li {
    color: var(--text-muted);
    font-size: 0.875rem;
    padding: 0.375rem 0;
    padding-left: 1.5rem;
    position: relative;
  }

  .info-box li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .btn-ghost:hover {
    border-color: var(--text-muted);
    color: var(--text-primary);
  }
</style>
