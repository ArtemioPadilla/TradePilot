---
import MainLayout from '../../layouts/MainLayout.astro';
import { ForgotPasswordForm } from '../../components/auth/ForgotPasswordForm';
const base = import.meta.env.BASE_URL;
---

<MainLayout title="Reset Password">
  <div class="auth-page">
    <div class="auth-container">
      <div class="auth-header">
        <a href={base} class="logo">
          <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="var(--accent)"/>
            <path d="M8 20L12 12L18 16L24 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="8" r="2" fill="white"/>
          </svg>
        </a>
        <h1>Reset password</h1>
        <p>We'll send you a link to reset your password</p>
      </div>

      <ForgotPasswordForm client:load />
    </div>
  </div>
</MainLayout>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .auth-container {
    width: 100%;
    max-width: 400px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .logo {
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .auth-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .auth-header p {
    color: var(--text-muted);
  }
</style>

<style is:global>
  .form-description {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .auth-footer-link {
    text-align: center;
    margin-top: 1.5rem;
  }

  .auth-footer-link a {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .auth-footer-link a:hover {
    color: var(--accent);
  }

  .success-state {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .success-icon {
    margin-bottom: 1.5rem;
  }

  .success-state h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .success-state p {
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .success-state .muted {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
