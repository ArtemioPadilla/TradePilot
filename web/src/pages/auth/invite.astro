---
import MainLayout from '../../layouts/MainLayout.astro';
import { RegisterForm } from '../../components/auth/RegisterForm';
const base = import.meta.env.BASE_URL;
---

<MainLayout title="Join TradePilot">
  <div class="auth-page">
    <div class="auth-container">
      <div class="auth-header">
        <a href={base} class="logo">
          <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="var(--accent)"/>
            <path d="M8 20L12 12L18 16L24 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="24" cy="8" r="2" fill="white"/>
          </svg>
        </a>
        <h1>You're invited!</h1>
        <p>Create your TradePilot account</p>
      </div>

      <div id="invite-status" class="invite-checking">
        <div class="loading-spinner">
          <svg width="24" height="24" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" stroke="var(--accent)" stroke-width="3" fill="none" stroke-dasharray="31.4" stroke-linecap="round">
              <animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/>
            </circle>
          </svg>
        </div>
        <p>Validating invite code...</p>
      </div>

      <div id="invite-valid" class="invite-content" style="display: none;">
        <div id="register-form-container"></div>

        <div class="auth-footer">
          <p>Already have an account? <a href={`${base}auth/login`}>Log in</a></p>
        </div>
      </div>

      <div id="invite-invalid" class="invite-error" style="display: none;" data-testid="invite-error">
        <div class="error-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--negative)" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="15" y1="9" x2="9" y2="15"/>
            <line x1="9" y1="9" x2="15" y2="15"/>
          </svg>
        </div>
        <h2>Invalid Invite</h2>
        <p id="error-message">This invite code is invalid or has expired.</p>
        <div class="error-actions">
          <a href={base} class="btn btn-secondary">Go to Homepage</a>
          <a href={`${base}auth/login`} class="btn btn-primary">Log In</a>
        </div>
      </div>

      <div id="no-code" class="invite-error" style="display: none;" data-testid="invite-error">
        <div class="error-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
        <h2>No Invite Code</h2>
        <p>No invite code provided. You need an invite code to create an account.</p>
        <div class="error-actions">
          <a href={base} class="btn btn-secondary">Go to Homepage</a>
          <a href={`${base}auth/login`} class="btn btn-primary">Log In</a>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<!-- Initial check for code parameter (runs immediately, no imports needed) -->
<script is:inline>
  (function() {
    const urlParams = new URLSearchParams(window.location.search);
    const code = urlParams.get('code');

    if (!code) {
      // No code provided - show the no-code message immediately
      const statusEl = document.getElementById('invite-status');
      const noCodeEl = document.getElementById('no-code');
      if (statusEl) statusEl.style.display = 'none';
      if (noCodeEl) noCodeEl.style.display = 'block';
      // Set a flag so the module script knows not to run
      window.__inviteCodeMissing = true;
    }
  })();
</script>

<!-- Module script for validation (only runs if code exists) -->
<script>
  import { validateInvite } from '../../lib/invites';
  import { RegisterForm } from '../../components/auth/RegisterForm';
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';

  // Skip if no code was provided (handled by inline script above)
  if (!window.__inviteCodeMissing) {
    checkInvite();
  }

  async function checkInvite() {
    const statusEl = document.getElementById('invite-status');
    const validEl = document.getElementById('invite-valid');
    const invalidEl = document.getElementById('invite-invalid');
    const errorMsgEl = document.getElementById('error-message');
    const formContainer = document.getElementById('register-form-container');

    // Get code from query parameters
    const urlParams = new URLSearchParams(window.location.search);
    const code = urlParams.get('code');

    if (!code) {
      // Should not reach here due to inline script, but handle just in case
      const noCodeEl = document.getElementById('no-code');
      if (statusEl) statusEl.style.display = 'none';
      if (noCodeEl) noCodeEl.style.display = 'block';
      return;
    }

    try {
      const result = await validateInvite(code);

      if (result.valid) {
        if (statusEl) statusEl.style.display = 'none';
        if (validEl) validEl.style.display = 'block';

        // Render the RegisterForm with the invite code
        if (formContainer) {
          const root = createRoot(formContainer);
          root.render(createElement(RegisterForm, { inviteCode: code }));
        }
      } else {
        if (statusEl) statusEl.style.display = 'none';
        if (invalidEl) invalidEl.style.display = 'block';
        if (errorMsgEl && result.error) {
          errorMsgEl.textContent = result.error;
        }
      }
    } catch (error) {
      if (statusEl) statusEl.style.display = 'none';
      if (invalidEl) invalidEl.style.display = 'block';
      if (errorMsgEl) {
        errorMsgEl.textContent = 'Unable to validate invite code. Please try again.';
      }
    }
  }
</script>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .auth-container {
    width: 100%;
    max-width: 400px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .logo {
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .auth-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .auth-header p {
    color: var(--text-muted);
  }

  .invite-checking {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 3rem;
    text-align: center;
  }

  .invite-checking .loading-spinner {
    margin-bottom: 1rem;
  }

  .invite-checking p {
    color: var(--text-muted);
  }

  .invite-error {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    text-align: center;
  }

  .error-icon {
    margin-bottom: 1.5rem;
  }

  .invite-error h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .invite-error p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .auth-footer {
    text-align: center;
    margin-top: 1.5rem;
  }

  .auth-footer p {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .auth-footer a {
    color: var(--accent);
    font-weight: 500;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
  }

  .btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-secondary);
  }

  .btn-secondary:hover {
    background: var(--border);
  }
</style>
