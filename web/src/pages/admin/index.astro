---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="admin-dashboard">
    <!-- Stats Cards -->
    <div class="stats-grid" id="stats-grid">
      <div class="stat-card">
        <div class="stat-icon pending">👤</div>
        <div class="stat-content">
          <span class="stat-value" id="pending-count">-</span>
          <span class="stat-label">Pending Approval</span>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon active">✓</div>
        <div class="stat-content">
          <span class="stat-value" id="active-count">-</span>
          <span class="stat-label">Active Users</span>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon suspended">⚠</div>
        <div class="stat-content">
          <span class="stat-value" id="suspended-count">-</span>
          <span class="stat-label">Suspended</span>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon total">👥</div>
        <div class="stat-content">
          <span class="stat-value" id="total-count">-</span>
          <span class="stat-label">Total Users</span>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="section">
      <h2>Quick Actions</h2>
      <div class="actions-grid">
        <a href="/admin/users?status=pending" class="action-card">
          <span class="action-icon">👤</span>
          <span class="action-label">Review Pending Users</span>
        </a>
        <a href="/admin/invites" class="action-card">
          <span class="action-icon">✉️</span>
          <span class="action-label">Manage Invites</span>
        </a>
        <button id="create-invite-btn" class="action-card">
          <span class="action-icon">➕</span>
          <span class="action-label">Create New Invite</span>
        </button>
      </div>
    </div>

    <!-- Recent Pending Users -->
    <div class="section">
      <div class="section-header">
        <h2>Pending Users</h2>
        <a href="/admin/users?status=pending" class="view-all">View All →</a>
      </div>
      <div class="users-list" id="pending-users">
        <div class="loading">Loading...</div>
      </div>
    </div>
  </div>

  <!-- Create Invite Modal -->
  <div class="modal" id="invite-modal">
    <div class="modal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3>Create Invite</h3>
        <button class="modal-close" id="close-modal">✕</button>
      </div>
      <form id="invite-form">
        <div class="form-group">
          <label class="label" for="invite-email">Email (Optional)</label>
          <input type="email" id="invite-email" class="input" placeholder="Restrict to specific email" />
        </div>
        <div class="form-group">
          <label class="label" for="invite-expires">Expires In</label>
          <select id="invite-expires" class="input">
            <option value="7">7 days</option>
            <option value="14">14 days</option>
            <option value="30" selected>30 days</option>
            <option value="0">Never</option>
          </select>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" id="cancel-invite">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Invite</button>
        </div>
      </form>
      <div id="invite-result" class="invite-result" style="display: none;">
        <p>Invite created! Share this link:</p>
        <div class="invite-link-box">
          <input type="text" id="invite-link" class="input" readonly />
          <button type="button" class="btn btn-primary" id="copy-link">Copy</button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { getAdminStats, getAllUsers, approveUser } from '../../lib/admin';
  import { createInvite, getInviteUrl } from '../../lib/invites';
  import { auth } from '../../lib/firebase';

  // Load stats
  async function loadStats() {
    try {
      const stats = await getAdminStats();
      document.getElementById('pending-count')!.textContent = stats.pendingUsers.toString();
      document.getElementById('active-count')!.textContent = stats.activeUsers.toString();
      document.getElementById('suspended-count')!.textContent = stats.suspendedUsers.toString();
      document.getElementById('total-count')!.textContent = stats.totalUsers.toString();
    } catch (error) {
      console.error('Failed to load stats:', error);
    }
  }

  // Load pending users
  async function loadPendingUsers() {
    const container = document.getElementById('pending-users')!;
    try {
      const users = await getAllUsers({ status: 'pending', limitCount: 5 });

      if (users.length === 0) {
        container.innerHTML = '<p class="empty-state">No pending users</p>';
        return;
      }

      container.innerHTML = users.map(user => `
        <div class="user-item" data-uid="${user.uid}">
          <div class="user-info">
            <span class="user-name">${user.displayName || 'No name'}</span>
            <span class="user-email">${user.email}</span>
          </div>
          <div class="user-actions">
            <button class="btn btn-sm btn-primary approve-btn" data-uid="${user.uid}">Approve</button>
          </div>
        </div>
      `).join('');

      // Add approve handlers
      container.querySelectorAll('.approve-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const uid = (e.target as HTMLElement).dataset.uid!;
          await approveUser(uid);
          loadPendingUsers();
          loadStats();
        });
      });
    } catch (error) {
      container.innerHTML = '<p class="error-state">Failed to load users</p>';
    }
  }

  // Modal handling
  const modal = document.getElementById('invite-modal')!;
  const createInviteBtn = document.getElementById('create-invite-btn')!;
  const closeModalBtn = document.getElementById('close-modal')!;
  const cancelInviteBtn = document.getElementById('cancel-invite')!;
  const inviteForm = document.getElementById('invite-form') as HTMLFormElement;
  const inviteResult = document.getElementById('invite-result')!;

  function openModal() {
    modal.classList.add('open');
    inviteForm.style.display = 'block';
    inviteResult.style.display = 'none';
  }

  function closeModal() {
    modal.classList.remove('open');
  }

  createInviteBtn.addEventListener('click', openModal);
  closeModalBtn.addEventListener('click', closeModal);
  cancelInviteBtn.addEventListener('click', closeModal);
  modal.querySelector('.modal-backdrop')!.addEventListener('click', closeModal);

  // Create invite
  inviteForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('invite-email') as HTMLInputElement).value;
    const expiresInDays = parseInt((document.getElementById('invite-expires') as HTMLSelectElement).value);

    try {
      const currentUser = auth.currentUser;
      if (!currentUser) return;

      const invite = await createInvite(currentUser.uid, {
        email: email || undefined,
        expiresInDays: expiresInDays || undefined,
      });

      const inviteUrl = getInviteUrl(invite.code);
      (document.getElementById('invite-link') as HTMLInputElement).value = inviteUrl;

      inviteForm.style.display = 'none';
      inviteResult.style.display = 'block';
    } catch (error) {
      console.error('Failed to create invite:', error);
      alert('Failed to create invite. Please try again.');
    }
  });

  // Copy link
  document.getElementById('copy-link')!.addEventListener('click', () => {
    const input = document.getElementById('invite-link') as HTMLInputElement;
    input.select();
    navigator.clipboard.writeText(input.value);
    document.getElementById('copy-link')!.textContent = 'Copied!';
    setTimeout(() => {
      document.getElementById('copy-link')!.textContent = 'Copy';
    }, 2000);
  });

  // Initialize
  loadStats();
  loadPendingUsers();
</script>

<style>
  .admin-dashboard {
    max-width: 1200px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .stat-icon.pending { background-color: rgba(255, 170, 0, 0.15); }
  .stat-icon.active { background-color: rgba(0, 200, 150, 0.15); }
  .stat-icon.suspended { background-color: rgba(255, 80, 80, 0.15); }
  .stat-icon.total { background-color: rgba(100, 150, 255, 0.15); }

  .stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .section {
    margin-bottom: 2rem;
  }

  .section h2 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .view-all {
    color: var(--accent);
    font-size: 0.875rem;
  }

  .actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .action-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    transition: all 0.15s ease;
    text-align: center;
  }

  .action-card:hover {
    border-color: var(--accent);
    background-color: var(--bg-tertiary);
  }

  .action-icon {
    font-size: 1.5rem;
  }

  .action-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .users-list {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .user-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .user-item:last-child {
    border-bottom: none;
  }

  .user-name {
    display: block;
    font-weight: 500;
  }

  .user-email {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
  }

  .empty-state,
  .error-state,
  .loading {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
  }

  /* Modal */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .modal.open {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
  }

  .modal-content {
    position: relative;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    width: 100%;
    max-width: 400px;
    margin: 1rem;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .modal-header h3 {
    font-size: 1.125rem;
  }

  .modal-close {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 1.25rem;
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    margin-top: 1.5rem;
  }

  .invite-result {
    text-align: center;
  }

  .invite-result p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
  }

  .invite-link-box {
    display: flex;
    gap: 0.5rem;
  }

  .invite-link-box input {
    flex: 1;
  }
</style>
