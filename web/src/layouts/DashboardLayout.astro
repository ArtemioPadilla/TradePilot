---
import '../styles/global.css';
import Sidebar from '../components/common/Sidebar.astro';
import Header from '../components/common/Header.astro';
import MobileNav from '../components/common/MobileNav.astro';
import AuthGuard from '../components/auth/AuthGuard';
import AuthInitializer from '../components/auth/AuthInitializer';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'TradePilot Dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a1a" />
    <link rel="preconnect" href="https://firestore.googleapis.com" crossorigin />
    <link rel="dns-prefetch" href="https://firestore.googleapis.com" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title} | TradePilot</title>
    <style>
      /* Hide content until auth is verified */
      .app-container { visibility: hidden; }
      .app-container.authenticated { visibility: visible; }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <!-- Initialize Firebase auth listener and guard protected content -->
    <AuthInitializer client:only="react" />
    <AuthGuard client:only="react" />

    <div class="app-container" id="app-container">
      <Sidebar />
      <div class="main-content">
        <Header title={title} />
        <main class="page-content" id="main-content">
          <slot />
        </main>
      </div>
      <MobileNav />
    </div>
    <script>
      import { initTheme } from '../stores/theme';
      import { initDensity } from '../stores/density';
      import '../lib/sw-register';
      initTheme();
      initDensity();
    </script>
  </body>
</html>

<style>
  .app-container {
    display: flex;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    margin-left: 240px;
    min-height: 100vh;
  }

  .page-content {
    flex: 1;
    padding: calc(1.5rem * var(--spacing-density));
    overflow-y: auto;
  }

  @media (max-width: 1024px) {
    .main-content {
      margin-left: 0;
    }
  }

  @media (max-width: 768px) {
    .page-content {
      padding-bottom: calc(5rem + env(safe-area-inset-bottom, 0));
    }
  }
</style>
