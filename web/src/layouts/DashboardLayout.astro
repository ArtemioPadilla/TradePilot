---
import '../styles/global.css';
import Sidebar from '../components/common/Sidebar.astro';
import Header from '../components/common/Header.astro';
import MobileNav from '../components/common/MobileNav.astro';
import AuthGuard from '../components/auth/AuthGuard';
import AuthInitializer from '../components/auth/AuthInitializer';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'TradePilot Dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a1a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | TradePilot</title>
    <style>
      /* Hide content until auth is verified */
      .app-container { visibility: hidden; }
      .app-container.authenticated { visibility: visible; }
    </style>
  </head>
  <body>
    <!-- Initialize Firebase auth listener and guard protected content -->
    <AuthInitializer client:only="react" />
    <AuthGuard client:only="react" />

    <div class="app-container" id="app-container">
      <Sidebar />
      <div class="main-content">
        <Header title={title} />
        <main class="page-content">
          <slot />
        </main>
      </div>
      <MobileNav />
    </div>
    <script>
      // Initialize theme from localStorage with system preference support
      import { initTheme } from '../stores/theme';
      import { initDensity } from '../stores/density';
      initTheme();
      initDensity();

      // Register service worker
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', async () => {
          try {
            const registration = await navigator.serviceWorker.register('/sw.js', {
              scope: '/',
            });

            // Check for updates periodically
            registration.addEventListener('updatefound', () => {
              const newWorker = registration.installing;
              if (newWorker) {
                newWorker.addEventListener('statechange', () => {
                  if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                    // New version available, notify user
                    console.log('[App] New version available');
                    // Dispatch custom event for UI to handle
                    window.dispatchEvent(new CustomEvent('sw-update-available', { detail: { registration } }));
                  }
                });
              }
            });

            console.log('[App] Service worker registered successfully');
          } catch (error) {
            console.error('[App] Service worker registration failed:', error);
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .app-container {
    display: flex;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    margin-left: 240px;
    min-height: 100vh;
  }

  .page-content {
    flex: 1;
    padding: calc(1.5rem * var(--spacing-density));
    overflow-y: auto;
  }

  @media (max-width: 1024px) {
    .main-content {
      margin-left: 0;
    }
  }

  @media (max-width: 768px) {
    .page-content {
      padding-bottom: calc(5rem + env(safe-area-inset-bottom, 0));
    }
  }
</style>
