---
import '../styles/global.css';
import AuthInitializer from '../components/auth/AuthInitializer';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'TradePilot - Integrated Backtesting and Live Trading Platform' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- PWA Meta Tags -->
    <meta name="theme-color" content="#6366f1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="TradePilot" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="application-name" content="TradePilot" />
    <meta name="msapplication-TileColor" content="#6366f1" />
    <meta name="msapplication-tap-highlight" content="no" />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://firestore.googleapis.com" crossorigin />
    <link rel="dns-prefetch" href="https://firestore.googleapis.com" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />

    <title>{title} | TradePilot</title>
  </head>
  <body>
    <!-- Initialize Firebase auth listener for auth-aware components -->
    <AuthInitializer client:only="react" />
    <slot />
    <script>
      import { initTheme } from '../stores/theme';
      import { initDensity } from '../stores/density';
      import '../lib/sw-register';
      initTheme();
      initDensity();
    </script>
  </body>
</html>
